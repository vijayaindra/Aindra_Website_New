# Firebase Web App (optional for now)
# Keep empty to run in static/local mode.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Feature flags (safe defaults)
# false = always use local static content
# true  = try Firebase first, fallback to static on errors/empty
VITE_USE_FIREBASE_CONTENT=false
VITE_FIREBASE_STORAGE_BASE_PATH=public
